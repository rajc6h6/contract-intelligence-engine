# ============================================================
# Contract Intelligence Engine — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Google Gemini API key (free tier works for all features)
# Get yours: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string
# When running via docker-compose, use:
DATABASE_URL=postgresql://cie_user:cie_password@localhost:5432/contract_intelligence

# ── Optional: Observability ──────────────────────────────────
# Logfire token for distributed tracing (free tier available)
# Get yours: https://logfire.pydantic.dev
# If not set, traces are printed to console only
LOGFIRE_TOKEN=

# Logfire project name (defaults to service name)
LOGFIRE_PROJECT_NAME=contract-intelligence-engine

# ── Service URLs (override for different deployments) ────────
MCP_SERVER_URL=http://localhost:8001/mcp
BACKEND_URL=http://localhost:8000

# ── LangGraph / Agent Config ─────────────────────────────────
# Gemini model for clause extraction and risk scoring
GEMINI_MODEL=gemini-2.0-flash
# Google embedding model for pgvector (768-dim)
EMBEDDING_MODEL=models/text-embedding-004

# Max retries for PydanticAI ValidationError recovery
MAX_EXTRACTION_RETRIES=3

# Risk score threshold: below this → auto-approve; at/above → human escalation
ESCALATION_THRESHOLD=40

# ── Server Config ─────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
MCP_PORT=8001
LOG_LEVEL=info

# ── Evals ─────────────────────────────────────────────────────
# Max hallucination rate before CI blocks merge (0.05 = 5%)
MAX_HALLUCINATION_RATE=0.05
